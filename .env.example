# =============================================================================
# Chess Tournament Entry Platform — Environment Variables Template
# Copy to .env and fill in all values. NEVER commit .env to git.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# PgBouncer URL (used by the app at runtime)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chess_tournament

# Direct Postgres URL (used by prisma migrate only — bypasses PgBouncer)
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/chess_tournament

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Use TEST keys locally (rzp_test_...)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Cloudflare R2 (use MinIO locally) ────────────────────────────────────────
R2_ACCOUNT_ID=local
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET_NAME=chess-tournament
R2_PUBLIC_URL=http://localhost:9000

# ── Notifications ─────────────────────────────────────────────────────────────
SENDGRID_API_KEY=

# ── Seed (Super Admin account) ────────────────────────────────────────────────
ADMIN_EMAIL=admin@easychess.local
ADMIN_INITIAL_PASSWORD=ChangeMe123!

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
