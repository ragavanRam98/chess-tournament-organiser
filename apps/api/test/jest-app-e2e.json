{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testRegex": "\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", {
      "tsconfig": "apps/api/test/tsconfig.e2e.json",
      "diagnostics": false
    }]
  },
  "coverageDirectory": "./coverage",
  "testEnvironment": "node",
  "roots": ["<rootDir>"],
  "testTimeout": 60000
}
