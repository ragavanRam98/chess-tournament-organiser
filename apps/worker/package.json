{
    "name": "@chess-tournament/worker",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "build": "nest build --config nest-cli.json",
        "dev": "nest start --watch --config nest-cli.json",
        "start": "node dist/worker.js",
        "lint": "eslint \"{src,test}/**/*.ts\" --fix",
        "type-check": "tsc --noEmit",
        "test": "jest"
    },
    "dependencies": {
        "@nestjs/common": "^10.3.0",
        "@nestjs/core": "^10.3.0",
        "@nestjs/bullmq": "^10.1.1",
        "@nestjs/config": "^3.2.0",
        "@prisma/client": "^5.11.0",
        "bullmq": "^5.4.0",
        "ioredis": "^5.3.2",
        "exceljs": "^4.4.0",
        "@aws-sdk/client-s3": "^3.540.0",
        "@aws-sdk/s3-request-presigner": "^3.540.0",
        "razorpay": "^2.9.2",
        "nodemailer": "^6.9.13",
        "@sendgrid/mail": "^8.1.3",
        "nestjs-pino": "^4.1.0",
        "pino-http": "^9.0.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.3.2",
        "@nestjs/testing": "^10.3.0",
        "@types/jest": "^29.5.12",
        "@types/node": "^20.12.7",
        "@types/nodemailer": "^6.4.14",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.2",
        "ts-node": "^10.9.2",
        "prisma": "^5.11.0"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "testEnvironment": "node"
    }
}